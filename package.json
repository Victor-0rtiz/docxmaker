{
  "name": "docxmaker",
  "version": "1.0.0",
  "description": "Lightweight DOCX generator for Node.js and browser apps using JSON definitions.",
  "author": "oss-dev",
  "license": "MIT",
  "keywords": [
    "docx",
    "docx generator",
    "document generator",
    "json to docx",
    "word",
    "office",
    "ooxml",
    "browser",
    "frontend",
    "nodejs",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Victor-0rtiz/docxmaker.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser/index.browser.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser/index.browser.d.ts",
      "import": "./dist/browser/index.browser.js"
    }
  },
  "scripts": {
    "build:node": "tsup src/index.ts --format esm,cjs --dts --out-dir dist --platform=node --target=node18",
    "build:web": "tsup --config tsup.config.browser.ts",
    "build": "npm run build:node && npm run build:web",
    "test:smoke": "node scripts/smoke-cross-runtime.mjs",
    "verify": "npm run build && npm run test:smoke"
  },
  "peerDependencies": {
    "jszip": "^3.10.1",
    "xmlbuilder2": "^4.0.3"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.1",
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
